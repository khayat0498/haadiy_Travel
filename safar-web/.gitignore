# ============================================================
# SAFAR — Monorepo .gitignore
# ============================================================

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/install-state.gz

# Next.js build
.next/
out/
.turbo/

# Production
build/
dist/

# Environment (keep examples)
.env
.env.local
.env*.local
!.env.example
!.env.local.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Testing / Coverage
coverage/
.nyc_output/

# Vercel
.vercel
