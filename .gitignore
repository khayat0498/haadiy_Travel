# ============================================================
# SAFAR — Root .gitignore (Travel monorepo)
# ============================================================

# OS
.DS_Store
Thumbs.db

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/install-state.gz

# Next.js build
**/.next/
**/out/
**/.turbo/

# Production builds
**/build/
**/dist/

# Environment files (keep examples)
.env
.env.local
.env*.local
**/.env
**/.env.local
**/.env*.local
!**/.env.example
!**/.env.local.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.vscode/
.idea/
*.swp
*.swo

# TypeScript
*.tsbuildinfo
**/next-env.d.ts

# Testing / Coverage
coverage/
.nyc_output/

# Vercel
.vercel

# Local cache
.cache/
